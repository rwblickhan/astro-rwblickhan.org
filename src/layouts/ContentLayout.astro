---
import type { MarkdownHeading } from "astro";
import MailIcon from "../components/MailIcon.astro";
import type { Collection } from "../content.config.ts";
import BaseLayout from "./BaseLayout.astro";

export interface Props {
  title: string;
  includeResponseLink?: boolean;
  description?: string;
  lastUpdatedDate?: Date;
  publicationDate?: Date;
  parentCollection?: Collection;
  floatImages?: boolean;
  headings?: MarkdownHeading[];
}

const {
  title = "R. W. Blickhan",
  description = "The personal site of R. W. Blickhan",
  includeResponseLink = true,
  lastUpdatedDate,
  publicationDate,
  parentCollection,
  floatImages = false,
  headings,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  lastUpdatedDate={lastUpdatedDate}
  publicationDate={publicationDate}
  width="small"
  parentCollection={parentCollection}
  shouldIndex={true}
  headings={headings}
>
  <hgroup>
    <h1>{title}</h1>
    {
      (lastUpdatedDate || publicationDate) && (
        <p>
          <strong>
            {lastUpdatedDate && (
              <span>Last updated: {lastUpdatedDate.toLocaleDateString()}</span>
            )}
            {lastUpdatedDate && publicationDate && <span> | </span>}
            {publicationDate && (
              <span>
                Originally published: {publicationDate.toLocaleDateString()}
              </span>
            )}
          </strong>
        </p>
      )
    }
  </hgroup>
  <div class:list={[{ "float-images": floatImages }]}>
    <slot />
  </div>
  {
    includeResponseLink && (
      <a
        href={`mailto:reply@rwblickhan.org?subject=${encodeURIComponent("Reply to " + title)}`}
      >
        <MailIcon />
        Reply by email!
      </a>
    )
  }
</BaseLayout>

<style>
  a {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
    margin-inline: auto;
    width: fit-content;
    border: 1px solid var(--text);
    border-radius: 8px;
    padding: 0.5rem;
  }

  a:hover {
    border-color: var(--primary);
  }

  p {
    text-align: center;
  }
</style>
