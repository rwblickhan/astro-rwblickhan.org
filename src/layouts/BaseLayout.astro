---
import Head from "../components/Head.astro";
import Nav from "../components/Nav.astro";
import PagefindSearch from "astro-pagefind/components/Search";
import "../styles/index.css";

// export interface Props {
//   title: string;
//   description: string;
//   width: "small" | "medium" | "large";
// }

const {
  title,
  description,
  width,
  lastUpdatedDate,
  publicationDate,
  parentCollection,
  shouldIndex,
} = Astro.props.frontmatter || Astro.props;
---

<!doctype html>
<html lang="en">
  <Head
    title={title}
    description={description}
    lastUpdatedDate={lastUpdatedDate}
    publicationDate={publicationDate}
  />
  <Nav parentCollection={parentCollection} />
  {
    shouldIndex ? (
      <main class={width} data-pagefind-body>
        <slot />
      </main>
    ) : (
      <main class={width}>
        <slot />
      </main>
    )
  }
  <dialog id="search-modal" popover>
    <PagefindSearch
      id="search"
      uiOptions={{ showSubResults: true, showImages: false }}
    />
  </dialog>
</html>

<style>
  main {
    padding: 0 1rem;
    margin-bottom: 1rem;
    container-type: inline-size;
  }

  @media (min-width: 768px) {
    main {
      margin-left: auto;
      margin-right: auto;

      &.small {
        max-width: 48rem;
      }

      &.medium {
        max-width: 64rem;
      }

      &.large {
        max-width: 80rem;
      }
    }
  }

  #search-modal {
    width: min(90vw, 48rem);
    max-height: 80vh;
    overflow-y: auto;
    border: none;
    border-radius: 0.5rem;
    padding: 1.5rem;
    background: var(--background);
    color: var(--text);
    position: fixed;
    top: 10vh;
    left: 50%;
    translate: -50% 0;
    margin: 0;
  }

  #search-modal::backdrop {
    background: rgba(0, 0, 0, 0.5);
  }
</style>

<script>
  const modal = document.getElementById("search-modal") as HTMLElement;
  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      modal?.showPopover();
    }
  });
</script>
