---
export function getStaticPaths() {
  const poetryIds = [
    "atnightheyrearrangethestreets",
    "faillingrain",
    "holdtheglassinyourhand",
    "somewhereachildisdreaming",
  ];
  return poetryIds.map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
return Astro.redirect(`/fiction/${id}`, 301);
---
